# =============================================================================
# Baara Environment Configuration
# =============================================================================
# Copy to .env and fill in values

# -----------------------------------------------------------------------------
# Environment
# -----------------------------------------------------------------------------
APP_ENV=development
APP_DEBUG=true
LOG_LEVEL=debug

# -----------------------------------------------------------------------------
# API Server
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8080
API_BASE_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# Web App
# -----------------------------------------------------------------------------
WEB_PORT=3000
WEB_BASE_URL=http://localhost:3000
VITE_API_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
DATABASE_URL=postgres://baara:baara_secret@localhost:5433/baara?sslmode=disable
DB_HOST=localhost
DB_PORT=5433
DB_USER=baara
DB_PASSWORD=baara_secret
DB_NAME=baara
DB_SSLMODE=disable
DB_MAX_OPEN_CONNS=25
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=5m

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# -----------------------------------------------------------------------------
# MinIO (S3-compatible storage)
# -----------------------------------------------------------------------------
MINIO_ENDPOINT=localhost:9010
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=baara-uploads
MINIO_USE_SSL=false
MINIO_REGION=us-east-1

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@baara.co
SMTP_FROM_NAME=Baara

# -----------------------------------------------------------------------------
# Worker
# -----------------------------------------------------------------------------
WORKER_CONCURRENCY=5
WORKER_QUEUE_EMAIL=email:queue

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
JWT_SECRET=change-this-in-production-to-a-long-random-string
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# -----------------------------------------------------------------------------
# Bootstrap Admin (optional, for first-time setup)
# -----------------------------------------------------------------------------
# Set these to auto-create the first admin on startup (if no admin exists)
# Remove after first deployment
# BOOTSTRAP_ADMIN_EMAIL=admin@baara.co
# BOOTSTRAP_ADMIN_NAME=Admin Baara

# -----------------------------------------------------------------------------
# Docker Images (for Dokploy)
# -----------------------------------------------------------------------------
API_IMAGE=baara-api:latest
WEB_IMAGE=baara-web:latest
WORKER_IMAGE=baara-worker:latest

# -----------------------------------------------------------------------------
# Domain Configuration (Production)
# -----------------------------------------------------------------------------
DOMAIN=baara.co
API_DOMAIN=api.baara.co
APP_DOMAIN=app.baara.co
